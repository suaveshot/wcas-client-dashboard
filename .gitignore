# -----------------------------------------------------------------------------
# wcas-client-dashboard  -  .gitignore
#
# This repository is PUBLIC. Anything containing secrets or client data must
# never be committed. If you need to add a new entry: always err on the side
# of blocking. When in doubt, add it.
# -----------------------------------------------------------------------------

# Secrets and environment
.env
.env.*
!.env.example
*.env.local
*.secret
*.secrets
secrets/
*token*.json
*credentials*.json
*refresh_token*
service_account*.json
*.pem
*.key
*.crt
*.p12
*.pfx

# Tenant data  -  never commit any per-client state
/opt/
tenant_config.json
brand.json
goals.json
baseline.json
activation_state.json
dashboard_decisions.jsonl
kb/
state/*.json
state_snapshot/

# Cost tracking + logs
costs.jsonl
*.log
logs/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.eggs/
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node (for any frontend tooling we add later)
node_modules/
npm-debug.log*
yarn-debug.log*
.pnp.*

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Editor
.vscode/
.idea/
*.swp
*~

# Build/CI artifacts
*.pid
*.lock
.docker/

# Backup artifacts
*.bak
*.backup
backups/

# Demo video working files (commit only the final link)
demo/raw/
demo/renders/
*.mp4
*.mov
