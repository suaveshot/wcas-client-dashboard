#!/usr/bin/env bash
# -----------------------------------------------------------------------------
# wcas-client-dashboard — pre-commit hook
#
# Blocks commits that include secrets, tenant data, or em dashes.
# Enable with: git config core.hooksPath .githooks
# -----------------------------------------------------------------------------

set -e

RED=$'\033[0;31m'
YELLOW=$'\033[0;33m'
GREEN=$'\033[0;32m'
RESET=$'\033[0m'

fail=0

# 1. Block accidentally-staged secret filenames.
# Iterate with NUL separators to handle filenames with spaces safely.
BANNED_PATTERNS=(
  '^\.env$'
  '(^|/)\.env\.(?!example$)'
  'tenant_config\.json$'
  'baseline\.json$'
  'goals\.json$'
  'brand\.json$'
  'dashboard_decisions\.jsonl$'
  '(^|/)token\.json$'
  '(^|/)credentials\.json$'
  'service_account.*\.json$'
  '\.pem$'
  '\.key$'
  '\.p12$'
  '\.pfx$'
)

while IFS= read -r -d '' path; do
  [ "$path" = ".env.example" ] && continue
  for pattern in "${BANNED_PATTERNS[@]}"; do
    if printf '%s' "$path" | grep -Pq "$pattern"; then
      printf '%sBLOCKED:%s %s matches banned pattern /%s/\n' \
        "$RED" "$RESET" "$path" "$pattern"
      fail=1
    fi
  done
done < <(git diff --cached --name-only --diff-filter=ACM -z)

# 2. Block common secret token patterns anywhere in staged diffs.
# Patterns: Anthropic, Google AI Studio, Google OAuth, Airtable PAT,
# Twilio SID+token, GitHub PATs (classic + fine-grained), Slack bot/user,
# AWS access keys, Stripe live keys, Connecteam, GHL location+api keys.
SECRET_REGEX='(sk-ant-api03-[A-Za-z0-9_\-]{80,}'
SECRET_REGEX+='|AIza[0-9A-Za-z_\-]{35,}'
SECRET_REGEX+='|GOCSPX-[A-Za-z0-9_\-]{20,}'
SECRET_REGEX+='|patl?[A-Za-z0-9]{14}\.[A-Za-z0-9]{30,}'
SECRET_REGEX+='|AC[a-f0-9]{32}'
SECRET_REGEX+='|ghp_[A-Za-z0-9]{36,}'
SECRET_REGEX+='|github_pat_[A-Za-z0-9_]{80,}'
SECRET_REGEX+='|xox[bp]-[A-Za-z0-9\-]{10,}'
SECRET_REGEX+='|AKIA[0-9A-Z]{16}'
SECRET_REGEX+='|sk_live_[A-Za-z0-9]{24,}'
SECRET_REGEX+='|ct_[a-z]{15,}_[a-f0-9]{32}'
SECRET_REGEX+='|pit-[a-f0-9-]{36}'
SECRET_REGEX+=')'

if git diff --cached | grep -Pq "$SECRET_REGEX"; then
  printf '%sBLOCKED:%s staged diff contains what looks like a real API key or token.\n' \
    "$RED" "$RESET"
  echo "  Move real values to .env (gitignored). Use placeholders in committed files."
  fail=1
fi

# 3. Block em dashes in code/content files.
#    Catches the literal U+2014 char AND HTML-entity encodings
#    (&mdash;, &#8212;, &#x2014;) that auto-paste from word processors.
#    Allowlist: detection files that must literally contain the char,
#    plus internal docs (audits/, JOURNAL.md) that quote the patterns
#    when documenting brand-rule violations.
EMDASH_ALLOWLIST='(tests/test_smoke\.py|\.githooks/pre-commit|docs/ci-templates/security\.yml\.template|^audits/|/audits/|JOURNAL\.md$)'
emdash_hits=$(
  git diff --cached --name-only --diff-filter=ACM \
    | grep -E '\.(py|html|md|css|js|yml|yaml|sh)$' \
    | grep -Ev "$EMDASH_ALLOWLIST" \
    | while read -r f; do
        if [ -f "$f" ] && grep -qE $'—|&mdash;|&#8212;|&#x2014;' "$f" 2>/dev/null; then echo "$f"; fi
      done
)
if [ -n "$emdash_hits" ]; then
  echo "${YELLOW}WARNING:${RESET} em dash (U+2014 or HTML entity) found in:"
  echo "$emdash_hits" | sed 's/^/  /'
  echo "  Use commas, periods, or spaced hyphens. This is a brand voice rule."
  fail=1
fi

if [ $fail -ne 0 ]; then
  echo ""
  echo "${RED}Pre-commit hook blocked this commit.${RESET}"
  echo "Fix the issues above, re-stage, and commit again."
  exit 1
fi

echo "${GREEN}Pre-commit checks passed.${RESET}"
exit 0
