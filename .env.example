# -----------------------------------------------------------------------------
# wcas-client-dashboard  -  .env.example
#
# Copy this file to .env and fill in the real values. The real .env is
# gitignored. Never commit real secrets.
# -----------------------------------------------------------------------------

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_BETA_HEADER=managed-agents-2026-04-01

# Airtable CRM Hub (read-only from dashboard's perspective; the n8n Client
# Onboarding workflow owns writes to the Clients table)
AIRTABLE_PAT=patREPLACE_ME
AIRTABLE_BASE_ID=appLAObkCBjDxSQg2
AIRTABLE_CLIENTS_TABLE_ID=tbl1XVlZJZ8rXAFOz
AIRTABLE_ACTIVITIES_TABLE_ID=tblIwgtKJktxk6Cdv
AIRTABLE_DEALS_TABLE_ID=tblF8hZ6TqBRncErz
AIRTABLE_LEADS_TABLE_ID=tblzFjZnbP55VBkP2
AIRTABLE_ONBOARDING_TASKS_TABLE_ID=tbl2Jbe4VY7bXuQEC

# Session + auth
SESSION_SECRET=generate-with-secrets-token-urlsafe-32
MAGIC_LINK_TTL_SECONDS=3600
COOKIE_NAME=wcas_session
COOKIE_DOMAIN=dashboard.westcoastautomationsolutions.com

# Heartbeat receiver (PC pushes AP state to VPS via this secret)
HEARTBEAT_SHARED_SECRET=generate-with-secrets-token-urlsafe-32

# Support path (Ask Sam)  -  emails via the same Gmail as AP's email assistant
SUPPORT_EMAIL_FROM=americalpatrol@gmail.com
SUPPORT_EMAIL_TO=salarcon@americalpatrol.com
GMAIL_APP_PASSWORD=REPLACE_ME

# Cost tracking + kill switch
DAILY_DEV_CAP=20
DAILY_TENANT_CAP=2.00
DEBUG_LOG_PROMPTS=false

# Demo mode (scrambles client names + redacts dollar values when true)
DEMO_MODE=false

# Deployment
VPS_HOST=dashboard.westcoastautomationsolutions.com
