# -----------------------------------------------------------------------------
# wcas-client-dashboard  -  .env.example
#
# Copy this file to .env and fill in the real values. The real .env is
# gitignored. Never commit real secrets.
# -----------------------------------------------------------------------------

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_BETA_HEADER=managed-agents-2026-04-01

# Airtable CRM Hub (read-only from dashboard's perspective; the n8n Client
# Onboarding workflow owns writes to the Clients table).
# Real base/table IDs live in a private .env, never in the public repo.
AIRTABLE_PAT=patREPLACE_ME
AIRTABLE_BASE_ID=appREPLACE_ME
AIRTABLE_CLIENTS_TABLE_ID=tblREPLACE_ME
AIRTABLE_ACTIVITIES_TABLE_ID=tblREPLACE_ME
AIRTABLE_DEALS_TABLE_ID=tblREPLACE_ME
AIRTABLE_LEADS_TABLE_ID=tblREPLACE_ME
AIRTABLE_ONBOARDING_TASKS_TABLE_ID=tblREPLACE_ME

# Session + auth
SESSION_SECRET=generate-with-secrets-token-urlsafe-32
MAGIC_LINK_TTL_SECONDS=3600
COOKIE_NAME=wcas_session
COOKIE_DOMAIN=dashboard.westcoastautomationsolutions.com

# Heartbeat receiver (PC pushes AP state to VPS via this secret)
HEARTBEAT_SHARED_SECRET=generate-with-secrets-token-urlsafe-32

# Support path (Ask Sam)  -  emails via the same Gmail as AP's email assistant
SUPPORT_EMAIL_FROM=americalpatrol@gmail.com
SUPPORT_EMAIL_TO=sam@westcoastautomationsolutions.com
GMAIL_APP_PASSWORD=REPLACE_ME

# Cost tracking + kill switch
DAILY_DEV_CAP=20
DAILY_TENANT_CAP=2.00
DEBUG_LOG_PROMPTS=false

# Demo mode (scrambles client names + redacts dollar values when true)
DEMO_MODE=false
DEMO_SCRAMBLE_SALT=generate-with-openssl-rand-hex-16

# Activation Orchestrator (Day 5) - Managed Agent model swap + per-tenant cap.
# Flip to claude-haiku-4-5-20251001 during dev to save credits; opus for demo.
ACTIVATION_AGENT_MODEL=claude-opus-4-7

# Dev-only test bypass for the onboarding approval gate (see clients_repo.py).
# The gate denies provisioning tools unless the tenant's Airtable Clients row
# has Onboarding Approved = true. Local dev may not have Airtable connectivity;
# set this to "1" to bypass. Refused at runtime when COOKIE_DOMAIN is the prod
# domain, so flipping this on by accident in prod still keeps the gate closed.
DISABLE_ONBOARDING_APPROVAL_GATE=0

# Sample-output generator overrides. Screenshots always go through Opus
# (multimodal quality matters) regardless of the agent's model.
WCAS_SCREENSHOT_MODEL=claude-opus-4-7

# §0.5 legal: the placeholder terms + privacy pages render at /legal/terms +
# /legal/privacy. Bumping CURRENT_TOS_VERSION in services/clients_repo.py
# invalidates every tenant's prior acceptance and forces re-click.

# §0 onboarding gate Airtable fields that must exist on the Clients table:
#   - Onboarding Approved         (checkbox, default false)
#   - Onboarding Completed At     (text / iso datetime, empty until wizard ends)
#   - TOS Version Accepted        (single-line text)
#   - TOS Accepted At             (single-line text)
#   - TOS Accepted IP             (single-line text)
#   - TOS Accepted UA             (single-line text)
# Sam adds these fields once; existing rows get Onboarding Approved ticked
# manually to preserve current access (AP, Garcia, admin self-test rows).

# Google OAuth client config (Day 4).
GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-REPLACE_ME
GOOGLE_OAUTH_REDIRECT_URI=https://dashboard.westcoastautomationsolutions.com/auth/oauth/google/callback

# Meta OAuth (Facebook + Instagram) - post-hackathon, keep empty for now.
# META_OAUTH_CLIENT_ID=
# META_OAUTH_CLIENT_SECRET=
# META_OAUTH_REDIRECT_URI=https://dashboard.westcoastautomationsolutions.com/auth/oauth/meta/callback

# Deployment
VPS_HOST=dashboard.westcoastautomationsolutions.com
